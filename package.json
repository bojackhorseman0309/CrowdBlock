{
  "name": "CrowdBlock",
  "version": "1.0.0",
  "description": "Simple Hardhat setup with a minimal Solidity contract for local/testnet experimentation.",
  "scripts": {
    "setup": "yarn install",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "local:node": "hardhat node --hostname 127.0.0.1 --port 8545",
    "local:deploy": "hardhat run scripts/deploy.js --network localhost",
    "local:interact": "cross-env HARDHAT_NETWORK=localhost node scripts/interact.js",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "local:voting:deploy": "hardhat run scripts/deploy-voting.js --network localhost",
    "local:voting:interact": "cross-env HARDHAT_NETWORK=localhost node scripts/interact-voting.js",
    "amoy:simple:deploy": "hardhat run scripts/deploy.js --network amoy",
    "amoy:simple:interact": "cross-env HARDHAT_NETWORK=amoy node scripts/interact.js",
    "amoy:voting:deploy": "hardhat run scripts/deploy-voting.js --network amoy",
    "amoy:voting:interact": "cross-env HARDHAT_NETWORK=amoy node scripts/interact-voting.js",
    "ui:voting": "node scripts/serve-voting-ui.js",
    "amoy:send-pol": "hardhat run scripts/send-pol-amoy.js --network amoy"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "typechain": "^8.3.2"
  }
}
